<Window x:Class="snapory.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:snapory"
        xmlns:services="clr-namespace:snapory.Services"
        mc:Ignorable="d"
        Title="snapory"
        Width="1000" Height="640"
        MinWidth="640" MinHeight="420"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Background="{DynamicResource WindowBg}">

    <!-- Remove the native title bar but keep resize/maximize/snap via WindowChrome.
         The custom title bar below is the draggable caption (CaptionHeight). -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" ResizeBorderThickness="6"
                      GlassFrameThickness="0" CornerRadius="0" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Small borderless "close" button shown in the custom title bar. -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="5" Background="{TemplateBinding Background}">
                            <TextBlock Text="✕" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SurfaceHover}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolToggle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="{DynamicResource ToolText}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" CornerRadius="6" Background="Transparent" Padding="11,6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SurfaceHover}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Accent}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CmdButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="Background" Value="{DynamicResource Surface}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="3,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="6" Background="{TemplateBinding Background}" Padding="12,6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SurfaceHover}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SurfaceDisabled}" />
                                <Setter Property="Foreground" Value="{DynamicResource DisabledText}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource CmdButton}">
            <Setter Property="Background" Value="{DynamicResource Accent}" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="SwatchToggle" TargetType="ToggleButton">
            <Setter Property="Width" Value="20" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" CornerRadius="10" Background="{TemplateBinding Background}"
                                BorderBrush="Transparent" BorderThickness="2" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource TextPrimary}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ShotItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" CornerRadius="8" Background="{DynamicResource Surface}"
                                BorderBrush="{DynamicResource Surface}" BorderThickness="2" Padding="5">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentDark}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- Custom title bar (the WindowChrome caption): brand mark + name, and a
             close button. Dragging it moves the window; the X needs to stay
             hit-testable inside the chrome caption area. -->
        <Border DockPanel.Dock="Top" Height="40" Background="{DynamicResource ToolbarBg}" Padding="12,0">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="15" Height="15" CornerRadius="4" Background="{DynamicResource Accent}" />
                    <TextBlock Text="snapory" Margin="9,0,0,0" FontWeight="SemiBold" FontSize="14"
                               Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
                </StackPanel>
                <Button DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center"
                        Style="{StaticResource CloseButtonStyle}" Click="OnCloseClick"
                        WindowChrome.IsHitTestVisibleInChrome="True" />
                <Border />
            </DockPanel>
        </Border>

        <!-- Toolbar: capture + drawing tools on the left, copy/save on the right. -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource ToolbarBg}" Padding="10,8">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource PrimaryButton}" Click="OnNew"
                            Content="{Binding [TrayCapture], Source={x:Static services:Localization.Instance}}" />
                    <Border Width="1" Background="{DynamicResource Divider}" Margin="8,2" />
                    <ToggleButton x:Name="ArrowTool" Style="{StaticResource ToolToggle}" Click="OnToolClick"
                                  Content="{Binding [ToolArrow], Source={x:Static services:Localization.Instance}}" />
                    <ToggleButton x:Name="BoxTool" Style="{StaticResource ToolToggle}" Click="OnToolClick"
                                  Content="{Binding [ToolBox], Source={x:Static services:Localization.Instance}}" />
                    <ToggleButton x:Name="HighlightTool" Style="{StaticResource ToolToggle}" Click="OnToolClick"
                                  Content="{Binding [ToolHighlight], Source={x:Static services:Localization.Instance}}" />
                    <ToggleButton x:Name="TextTool" Style="{StaticResource ToolToggle}" Click="OnToolClick"
                                  Content="{Binding [ToolText], Source={x:Static services:Localization.Instance}}" />
                    <Border Width="1" Background="{DynamicResource Divider}" Margin="8,2" />
                    <StackPanel x:Name="SwatchPanel" Orientation="Horizontal" VerticalAlignment="Center" />
                    <Border Width="1" Background="{DynamicResource Divider}" Margin="8,2" />
                    <Button x:Name="UndoButton" Style="{StaticResource CmdButton}" Click="OnUndo"
                            Content="{Binding [Undo], Source={x:Static services:Localization.Instance}}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="CopyButton" Style="{StaticResource CmdButton}" Click="OnCopy"
                            Content="{Binding [Copy], Source={x:Static services:Localization.Instance}}" />
                    <Button x:Name="SaveButton" Style="{StaticResource PrimaryButton}" Click="OnSave"
                            Content="{Binding [Save], Source={x:Static services:Localization.Instance}}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="248" />
            </Grid.ColumnDefinitions>

            <!-- Left: the editing canvas. -->
            <Grid Grid.Column="0">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                              Background="{DynamicResource WindowBg}" Padding="16">
                    <Grid x:Name="EditSurface" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image x:Name="ShotImage" />
                        <Canvas x:Name="Annotations" Background="Transparent"
                                MouseLeftButtonDown="OnCanvasDown"
                                MouseMove="OnCanvasMove"
                                MouseLeftButtonUp="OnCanvasUp" />
                    </Grid>
                </ScrollViewer>
                <TextBlock x:Name="EmptyState"
                           Text="{Binding [HistoryEmpty], Source={x:Static services:Localization.Instance}}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           TextAlignment="Center" TextWrapping="Wrap" MaxWidth="340"
                           FontSize="13" Foreground="{DynamicResource TextMuted}" IsHitTestVisible="False" />
            </Grid>

            <!-- Right: the history list + its actions. -->
            <DockPanel Grid.Column="1" Background="{DynamicResource PanelBg}">
                <Border DockPanel.Dock="Bottom" Padding="10,8">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button x:Name="DeleteButton" Style="{StaticResource CmdButton}" Click="OnDelete"
                                Content="{Binding [Delete], Source={x:Static services:Localization.Instance}}" />
                        <Button Style="{StaticResource CmdButton}" Click="OnClearAll"
                                Content="{Binding [ClearAll], Source={x:Static services:Localization.Instance}}" />
                    </StackPanel>
                </Border>
                <ListBox x:Name="ShotList"
                         Background="{DynamicResource PanelBg}" BorderThickness="1,0,0,0"
                         BorderBrush="{DynamicResource Divider}"
                         ItemContainerStyle="{StaticResource ShotItem}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         Padding="8" SelectionChanged="OnSelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <Border CornerRadius="4" ClipToBounds="True" Background="{DynamicResource ThumbBg}" Height="120">
                                    <Image Source="{Binding Thumbnail}" Stretch="Uniform" />
                                </Border>
                                <TextBlock Text="{Binding Caption}" Margin="2,5,0,0"
                                           FontSize="11" Foreground="{DynamicResource TextMuted}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
