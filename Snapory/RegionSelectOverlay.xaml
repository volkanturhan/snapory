<Window x:Class="Snapory.RegionSelectOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="clr-namespace:Snapory.Services"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        Background="Black"
        Cursor="Cross"
        FontFamily="Segoe UI">
    <Grid x:Name="Root">

        <!-- The frozen desktop, full brightness, at the bottom. -->
        <Image x:Name="ScreenImage" Stretch="Fill" />

        <!-- A dim veil over everything... -->
        <Rectangle Fill="#73000000" />

        <!-- ...with a bright copy of the desktop punched through the selection. -->
        <Image x:Name="BrightImage" Stretch="Fill" Visibility="Collapsed" />

        <Canvas x:Name="Overlay" IsHitTestVisible="False">
            <!-- Selection outline. -->
            <Rectangle x:Name="SelectionRect" Stroke="#3B82F6" StrokeThickness="1.5"
                       Visibility="Collapsed" />
            <!-- Size readout near the selection. -->
            <Border x:Name="SizeBadge" CornerRadius="4" Background="#CC111827"
                    Padding="6,3" Visibility="Collapsed">
                <TextBlock x:Name="SizeText" Foreground="White" FontSize="12" />
            </Border>
        </Canvas>

        <!-- Bottom hint. -->
        <Border VerticalAlignment="Bottom" HorizontalAlignment="Center"
                Margin="0,0,0,40" CornerRadius="8" Background="#CC111827"
                Padding="14,8" IsHitTestVisible="False">
            <TextBlock Text="{Binding [SelectHint], Source={x:Static services:Localization.Instance}}"
                       Foreground="White" FontSize="13" />
        </Border>
    </Grid>
</Window>
